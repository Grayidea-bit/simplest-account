{
  "name": "simplest-account",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:web && wrangler dev",
    "build:web": "vite build",
    "check": "tsc -p . --noEmit && tsc -p web --noEmit",
    "build": "npm run check && vite build",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "vite": "^6.0.0",
    "typescript": "^5.6.0",
    "@cloudflare/workers-types": "^5.20260708.0"
  }
}
